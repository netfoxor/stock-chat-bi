# 「docker compose」默认不含 MySQL 容器：连宿主/1Panel 上的库，`DATABASE_URL` 主机可用 host.docker.internal（根 compose 已配 extra_hosts）
# DATABASE_URL=mysql+aiomysql://USER:PASSWORD@host.docker.internal:3306/stock?charset=utf8mb4
#
# 「docker-compose-with-mysql.yml」或本机直跑后端（uvicorn）：
DATABASE_URL=mysql+aiomysql://root:root@localhost:3306/stock?charset=utf8mb4
JWT_SECRET=please-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRES_DAYS=7
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000
# 生产必填：浏览器访问前台的完整 Origin（协议+域名+端口），多个用英文逗号；
# 同源 Nginx 代理 /api 时也建议写上，否则浏览器带 Origin 且与下述列表不一致时可能被 CORS 拦截（AI 对话 /chat/stream 会失败）
# CORS_ALLOW_ORIGINS=https://stock.example.com,http://stock.example.com

# Tushare（backend/fetch_stock_prices.py）
# TUSHARE_TOKEN=your-token

# AkShare 沪深京股票列表入库（backend/fetch_stock_codes.py）；与上共用 DATABASE_URL；可重复执行，仅 INSERT 新增的 ts_code

# LLM
# DASHSCOPE_API_KEY=your-key

# OpenAI-compatible（用于接入阿里 Coding Plan 等 OpenAI 接口网关；对应 nanobot 配置里的 providers.openai.api_base）
# OPENAI_API_KEY=your-key
# OPENAI_BASE_URL=https://your-gateway.example.com/v1
# OPENAI_MODEL=qwen-coder

# 可选：强制指定 provider（openai | dashscope），不填则自动判断：有 OPENAI_API_KEY 就走 openai
# NANOBOT_PROVIDER=openai

