# --- 必填 ---
# 阿里云 DashScope API Key（通义千问）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chainlit 登录 Cookie / JWT 签名密钥
# 生成方法：命令行执行 `chainlit create-secret`，把输出的那串粘贴过来
CHAINLIT_AUTH_SECRET=please-run-chainlit-create-secret-and-paste-here

# --- 可选 ---
# Chainlit 登录凭据（默认 admin/admin，仅限本地/内网使用，对外暴露请务必改掉）
# CHAINLIT_USERNAME=admin
# CHAINLIT_PASSWORD=admin

# 聊天历史 SQLite 文件路径（默认 memory/chainlit.db）
# CHAINLIT_DB_PATH=/data/chainlit.db

# 覆盖模型（不填则用 config.json 里的 qwen3.6-plus）
# QWEN_AGENT_MODEL=qwen3.6-plus

# 映射到 host 的端口（默认 10001）
# HOST_PORT=10001
